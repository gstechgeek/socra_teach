# ── Local LLM (llama.cpp / Vulkan) ──────────────────────────────────────────
# Path is relative to the backend/ working directory
MODEL_PATH=../models/llama-3.2-1b-instruct-q4_k_m.gguf
N_GPU_LAYERS=-1        # -1 = offload all layers to Vulkan
N_CTX=4096             # HARD LIMIT — do not increase (KV cache OOM)
MAX_TOKENS=512

# ── OpenRouter (cloud LLM fallback) ──────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Cloud model tiers (change only if you want to swap to a different model)
CLOUD_MODEL_DIALOGUE=anthropic/claude-sonnet-4-5
CLOUD_MODEL_REASONING=deepseek/deepseek-r1
CLOUD_MODEL_FAST=anthropic/claude-haiku-4-5

# ── Embeddings ───────────────────────────────────────────────────────────────
EMBEDDING_PROVIDER=local          # "local" (sentence-transformers) or "openrouter" (cloud)
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
CLOUD_EMBEDDING_MODEL=openai/text-embedding-3-small   # or openai/text-embedding-3-large
EMBEDDING_DIM=256      # Matryoshka reduced dimension (full = 768)

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-anon-key-here

# ── LanceDB (local vector store) ─────────────────────────────────────────────
LANCEDB_PATH=../data/lancedb
